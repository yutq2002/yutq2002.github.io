---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const cvZh = await getEntry("spec", "cv");
const cvEn = await getEntry("spec", "cv-en");

if (!cvZh || !cvEn) {
	throw new Error("CV page content not found");
}

const { Content: ContentZh } = await render(cvZh);
const { Content: ContentEn } = await render(cvEn);
---
<MainGridLayout title={i18n(I18nKey.cv)} titleI18nKey={I18nKey.cv} description={i18n(I18nKey.cv)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <div data-lang-panel="zh_CN">
                <Markdown class="mt-2">
                    <ContentZh />
                </Markdown>
            </div>
            <div data-lang-panel="en" class="hidden">
                <Markdown class="mt-2">
                    <ContentEn />
                </Markdown>
            </div>
        </div>
    </div>
</MainGridLayout>
